<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme using Material 3 -->
    <style name="Base.AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#00FF41</item> <!-- Matrix Green -->
        <item name="android:statusBarColor">@android:color/black</item>
    </style>

    <style name="AppTheme" parent="Base.AppTheme" />

    <!-- Fullscreen style for SplashActivity -->
    <style name="Theme.AppCompat.NoActionBar.FullScreen" parent="Base.AppTheme">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Unified Security Dialog Theme (Fixed for MainActivity) -->
    <style name="SecurityDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:textColorPrimary">#00FF41</item> <!-- Matrix Green -->
        <item name="colorAccent">#00FF41</item>
    </style>

</resources>
