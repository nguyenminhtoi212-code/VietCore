<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="#000000"
     android:orientation="vertical"
     android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
         android:layout_height="?attr/actionBarSize"
         android:layout_width="match_parent"
         android:background="#000000"
         app:title="@string/settings_title"
         app:titleTextColor="#00FF41"
         android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
         android:id="@+id/toolbar_settings" />

    <ScrollView
         android:layout_height="match_parent"
         android:layout_width="match_parent"
         android:scrollbarThumbVertical="@null">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:padding="20dp"
             android:orientation="vertical">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="12dp"
                 android:fontFamily="monospace"
                 android:textSize="12sp"
                 android:textColor="#888888"
                 android:text="@string/header_identity" />

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:background="#0D0D0D"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:padding="16dp"
                 android:orientation="horizontal"
                 android:focusable="true"
                 android:id="@+id/btn_account_profile"
                 android:foreground="?android:attr/selectableItemBackground">

                <com.google.android.material.imageview.ShapeableImageView
                     android:layout_height="60dp"
                     android:layout_width="60dp"
                     android:src="@drawable/ic_my_icon"
                     app:strokeColor="#00FF41"
                     android:padding="2dp"
                     app:shapeAppearanceOverlay="@style/CircleAppearance"
                     app:strokeWidth="1dp"
                     android:id="@+id/img_user_avatar" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:orientation="vertical"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:fontFamily="monospace"
                         android:textSize="16sp"
                         android:textColor="#FFFFFF"
                         android:id="@+id/tv_username"
                         android:text="Nguyen Minh Toi"
                         android:textStyle="bold" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:fontFamily="monospace"
                         android:textSize="11sp"
                         android:textColor="#00FF41"
                         android:text="@string/status_authorized" />

                </LinearLayout>

                <ImageView
                     android:layout_height="20dp"
                     android:layout_width="20dp"
                     android:src="@android:drawable/ic_menu_edit"
                     app:tint="#444444" />

            </LinearLayout>

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:layout_marginVertical="16dp"
                 android:background="#1A1A1A" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="8dp"
                 android:fontFamily="monospace"
                 android:textSize="12sp"
                 android:textColor="#888888"
                 android:text="@string/header_security" />

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:background="?android:attr/selectableItemBackground"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:paddingHorizontal="8dp"
                 android:id="@+id/btn_manage_permissions">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_manage"
                     app:tint="#00FFFF" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:fontFamily="monospace"
                     android:textSize="14sp"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1"
                     android:text="@string/item_permissions" />

            </LinearLayout>

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:layout_marginVertical="16dp"
                 android:background="#1A1A1A" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="8dp"
                 android:fontFamily="monospace"
                 android:textSize="12sp"
                 android:textColor="#888888"
                 android:text="@string/header_localization" />

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:background="?android:attr/selectableItemBackground"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:paddingHorizontal="8dp"
                 android:id="@+id/btn_change_language">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_sort_alphabetically"
                     app:tint="#FFCC00" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:orientation="vertical"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:fontFamily="monospace"
                         android:textSize="14sp"
                         android:textColor="#FFFFFF"
                         android:text="@string/item_language" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:fontFamily="monospace"
                         android:textSize="11sp"
                         android:textColor="#00FF41"
                         android:id="@+id/tv_current_language"
                         android:text="English (US)" />

                </LinearLayout>

                <ImageView
                     android:layout_height="20dp"
                     android:layout_width="20dp"
                     android:src="@android:drawable/ic_media_play"
                     app:tint="#444444" />

            </LinearLayout>

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:layout_marginVertical="16dp"
                 android:background="#1A1A1A" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="8dp"
                 android:fontFamily="monospace"
                 android:textSize="12sp"
                 android:textColor="#888888"
                 android:text="@string/header_appearance" />

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:paddingHorizontal="8dp"
                 android:focusable="true"
                 android:id="@+id/btn_light_mode">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_day"
                     app:tint="#888888" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:fontFamily="monospace"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1"
                     android:text="@string/item_light_mode" />

                <RadioButton
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:clickable="false"
                     android:id="@+id/radio_light" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:paddingHorizontal="8dp"
                 android:focusable="true"
                 android:id="@+id/btn_dark_mode">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_recent_history"
                     app:tint="#00FF41" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:fontFamily="monospace"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1"
                     android:text="@string/item_dark_mode" />

                <RadioButton
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:clickable="false"
                     android:id="@+id/radio_dark" />

            </LinearLayout>

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:layout_marginVertical="16dp"
                 android:background="#1A1A1A" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="8dp"
                 android:fontFamily="monospace"
                 android:textSize="12sp"
                 android:textColor="#00FF41"
                 android:text="@string/header_system_intel" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:background="#0D0D0D"
                 android:clickable="true"
                 android:padding="12dp"
                 android:fontFamily="monospace"
                 android:textSize="11sp"
                 android:textColor="#CCCCCC"
                 android:id="@+id/tv_whats_new_content"
                 android:text="@string/intel_logs_default" />

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:background="?android:attr/selectableItemBackground"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:paddingHorizontal="8dp"
                 android:id="@+id/btn_integrity_check">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_compass"
                     app:tint="#00FF41" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:fontFamily="monospace"
                     android:textSize="13sp"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:text="@string/item_integrity_scan" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:background="?android:attr/selectableItemBackground"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:paddingHorizontal="8dp"
                 android:id="@+id/btn_clear_cache">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_delete"
                     app:tint="#00FFFF" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:fontFamily="monospace"
                     android:textSize="13sp"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:text="@string/item_purge_cache" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:gravity="center_vertical"
                 android:paddingHorizontal="8dp">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_preferences"
                     app:tint="#FF8800" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:fontFamily="monospace"
                     android:textSize="13sp"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1"
                     android:text="@string/item_experimental" />

                <androidx.appcompat.widget.SwitchCompat
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:id="@+id/sw_experimental" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:background="?android:attr/selectableItemBackground"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:paddingHorizontal="8dp"
                 android:id="@+id/btn_legal_policy">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_info_details"
                     app:tint="#00FFFF" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:fontFamily="monospace"
                     android:textSize="13sp"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:text="@string/item_terms" />

            </LinearLayout>

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:layout_marginVertical="16dp"
                 android:background="#1A1A1A" />

            <Button
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:fontFamily="monospace"
                 android:backgroundTint="#00FF41"
                 android:textColor="#000000"
                 android:id="@+id/btn_apply_settings"
                 android:text="@string/btn_apply" />

            <Button
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:fontFamily="monospace"
                 android:backgroundTint="#FF0000"
                 android:textColor="#FFFFFF"
                 android:layout_marginTop="12dp"
                 android:id="@+id/btn_system_recovery"
                 android:text="@string/btn_recovery" />

            <Space
                 android:layout_height="48dp"
                 android:layout_width="match_parent" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>