<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="#000000"
     android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
         android:layout_height="?attr/actionBarSize"
         android:layout_width="match_parent"
         android:background="#000000"
         app:titleTextColor="#00FF41"
         android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
         android:id="@+id/toolbar_settings" />

    <ScrollView
         android:layout_height="match_parent"
         android:layout_width="match_parent">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:padding="20dp"
             android:orientation="vertical">

            <ImageView
                 android:layout_height="64dp"
                 android:layout_width="64dp"
                 android:layout_marginBottom="12dp"
                 android:src="@drawable/ic_my_icon"
                 android:contentDescription="@string/app_name"
                 android:layout_gravity="center" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:gravity="center"
                 android:fontFamily="monospace"
                 android:textSize="16sp"
                 android:textColor="#00FF41"
                 android:text="VIETCORE CONFIGURATION"
                 android:textStyle="bold" />

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:layout_marginBottom="16dp"
                 android:background="#1A1A1A"
                 android:layout_marginTop="16dp" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="8dp"
                 android:textSize="12sp"
                 android:fontFamily="monospace"
                 android:textColor="#888888"
                 android:text="APPEARANCE" />

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:paddingEnd="8dp"
                 android:background="?android:attr/selectableItemBackground"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:orientation="horizontal"
                 android:paddingStart="8dp"
                 android:focusable="true"
                 android:id="@+id/btn_light_mode">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_day"
                     app:tint="#888888" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:fontFamily="monospace"
                     android:textSize="14sp"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1"
                     android:text="Light Mode (White)" />

                <RadioButton
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:clickable="false"
                     android:id="@+id/radio_light" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:paddingEnd="8dp"
                 android:background="?android:attr/selectableItemBackground"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:orientation="horizontal"
                 android:paddingStart="8dp"
                 android:focusable="true"
                 android:id="@+id/btn_dark_mode">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_recent_history"
                     app:tint="#00FF41" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:fontFamily="monospace"
                     android:textSize="14sp"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1"
                     android:text="Dark Mode (Black)" />

                <RadioButton
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:clickable="false"
                     android:id="@+id/radio_dark" />

            </LinearLayout>

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:layout_marginBottom="16dp"
                 android:background="#1A1A1A"
                 android:layout_marginTop="16dp" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="8dp"
                 android:textSize="12sp"
                 android:fontFamily="monospace"
                 android:textColor="#888888"
                 android:text="SYSTEM PERMISSIONS" />

            <LinearLayout
                 android:layout_height="56dp"
                 android:layout_width="match_parent"
                 android:paddingEnd="8dp"
                 android:background="?android:attr/selectableItemBackground"
                 android:gravity="center_vertical"
                 android:clickable="true"
                 android:paddingStart="8dp"
                 android:focusable="true"
                 android:id="@+id/btn_manage_permissions">

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@android:drawable/ic_menu_manage"
                     app:tint="#00FFFF" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:fontFamily="monospace"
                     android:textSize="14sp"
                     android:textColor="#FFFFFF"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1"
                     android:text="App Permissions" />

                <ImageView
                     android:layout_height="20dp"
                     android:layout_width="20dp"
                     android:src="@android:drawable/ic_media_play"
                     app:tint="#444444" />

            </LinearLayout>

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:layout_marginBottom="16dp"
                 android:background="#1A1A1A"
                 android:layout_marginTop="16dp" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="8dp"
                 android:textSize="12sp"
                 android:fontFamily="monospace"
                 android:textColor="#00FF41"
                 android:text="WHAT'S NEW" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:background="#0D0D0D"
                 android:clickable="true"
                 android:padding="12dp"
                 android:fontFamily="monospace"
                 android:textSize="11sp"
                 android:textColor="#CCCCCC"
                 android:focusable="true"
                 android:id="@+id/tv_whats_new_content"
                 android:foreground="?android:attr/selectableItemBackground"
                 android:text="> Java source encrypted\n> Hardware analytics enabled\n> System transitions optimized" />

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:layout_marginBottom="16dp"
                 android:background="#1A1A1A"
                 android:layout_marginTop="24dp" />

            <Button
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:fontFamily="monospace"
                 android:backgroundTint="#00FF41"
                 android:textColor="#000000"
                 android:id="@+id/btn_apply_settings"
                 android:text="APPLY CHANGES" />

            <Button
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:fontFamily="monospace"
                 android:backgroundTint="#FF0000"
                 android:textColor="#FFFFFF"
                 android:layout_marginTop="12dp"
                 android:id="@+id/btn_system_recovery"
                 android:text="SYSTEM RECOVERY" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
