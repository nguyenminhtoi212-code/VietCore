<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:tools="http://schemas.android.com/tools"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="#000000"
     android:padding="20dp"
     android:orientation="vertical"
     android:fitsSystemWindows="true"
     tools:context=".LegalActivity">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_marginBottom="12dp"
         android:background="?attr/selectableItemBackground"
         android:clickable="true"
         android:padding="8dp"
         android:orientation="vertical"
         android:focusable="true"
         android:id="@+id/btn_legal_policy_header">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="18sp"
             android:textColor="#00FF41"
             android:id="@+id/tv_legal_title"
             android:text="LEGAL AND TERMS OF USE"
             android:textStyle="bold" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="10sp"
             android:textColor="#888888"
             android:layout_marginTop="2dp"
             android:id="@+id/tv_legal_subtitle"
             android:text="View authority and system compliance" />

    </LinearLayout>

    <ScrollView
         android:layout_height="0dp"
         android:layout_width="match_parent"
         android:background="#0A0A0A"
         android:fadeScrollbars="false"
         android:padding="12dp"
         android:layout_weight="1"
         android:scrollbarThumbVertical="@android:color/darker_gray">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:fontFamily="monospace"
             android:textSize="12sp"
             android:textColor="#CCCCCC"
             android:lineSpacingExtra="5dp"
             android:id="@+id/tv_legal_content"
             android:text="> Initializing VietCore Legal Protocol...\n> ID: VC-AUTH-2026\n> Dev: Nguyen Minh Toi\n\n[ĐIỀU KHOẢN SỬ DỤNG]\n1. Hệ thống VietCore Intelligence yêu cầu quyền truy cập phần cứng để bảo mật.\n2. Mọi hành vi can thiệp trái phép vào Kernel sẽ bị khóa ID thiết bị.\n3. Dữ liệu được bảo mật bởi lá chắn RSA-4096.\n\n> Đang chờ xác nhận từ người dùng..." />

    </ScrollView>

    <CheckBox
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:buttonTint="#00FF41"
         android:fontFamily="monospace"
         android:textSize="11sp"
         android:textColor="#00FF41"
         android:layout_marginTop="12dp"
         android:id="@+id/cb_agree"
         android:text="I agree to the terms and security protocols" />

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_marginBottom="8dp"
         android:gravity="center"
         android:orientation="horizontal"
         android:layout_marginTop="10dp">

        <Button
             android:layout_height="45dp"
             android:layout_width="0dp"
             android:layout_marginEnd="6dp"
             android:fontFamily="monospace"
             android:textSize="12sp"
             android:backgroundTint="#FF0000"
             android:textColor="#FFFFFF"
             android:layout_weight="1"
             android:id="@+id/btn_decline"
             android:text="DECLINE" />

        <Button
             android:layout_height="45dp"
             android:layout_width="0dp"
             android:fontFamily="monospace"
             android:textSize="12sp"
             android:backgroundTint="#00FF41"
             android:textColor="#000000"
             android:enabled="false"
             android:layout_marginStart="6dp"
             android:layout_weight="1"
             android:id="@+id/btn_accept"
             android:text="ACCEPT" />

    </LinearLayout>

</LinearLayout>