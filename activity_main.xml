<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     xmlns:tools="http://schemas.android.com/tools"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="#000000"
     android:fitsSystemWindows="true"
     tools:context=".MainActivity">

    <TextView
         android:layout_height="wrap_content"
         android:layout_width="wrap_content"
         app:layout_constraintTop_toTopOf="parent"
         android:layout_margin="12dp"
         app:layout_constraintStart_toStartOf="parent"
         android:fontFamily="monospace"
         android:textSize="11sp"
         android:textColor="#00FF41"
         android:id="@+id/tv_security_status"
         android:text="OMNIS SECURITY: MONITORING ACTIVE"
         android:textStyle="bold" />

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="wrap_content"
         android:orientation="vertical"
         app:layout_constraintStart_toStartOf="parent"
         android:layout_marginTop="2dp"
         android:layout_marginStart="12dp"
         app:layout_constraintTop_toBottomOf="@id/tv_security_status"
         android:id="@+id/ll_header_info">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="9sp"
             android:textColor="#666666"
             android:id="@+id/tv_author"
             android:text="Developer: Nguyen Minh Toi" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="9sp"
             android:textColor="#00CCCC"
             android:id="@+id/tv_version"
             android:text="Core: VietCore 26.1.4-Beta" />

    </LinearLayout>

    <View
         android:layout_height="0.5dp"
         android:layout_width="match_parent"
         android:background="#1A1A1A"
         android:layout_marginHorizontal="12dp"
         android:layout_marginTop="8dp"
         app:layout_constraintTop_toBottomOf="@id/ll_header_info"
         android:id="@+id/divider" />

    <ScrollView
         android:layout_height="0dp"
         android:layout_width="match_parent"
         android:scrollbars="none"
         android:layout_marginTop="4dp"
         app:layout_constraintBottom_toBottomOf="parent"
         android:paddingHorizontal="12dp"
         app:layout_constraintTop_toBottomOf="@id/divider">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:orientation="vertical"
             android:paddingBottom="80dp">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:fontFamily="monospace"
                 android:textSize="12sp"
                 android:textColor="#DDDDDD"
                 android:lineSpacingExtra="3dp"
                 android:id="@+id/tv_device_info"
                 android:text="[ INJECTING VIETCORE KERNEL... ]\n[ INITIALIZING REAL-TIME SPECS... ]" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
         android:layout_height="match_parent"
         android:layout_width="match_parent"
         android:visibility="gone"
         android:background="#000000"
         android:gravity="center"
         android:clickable="true"
         android:elevation="50dp"
         android:padding="20dp"
         android:orientation="vertical"
         android:focusable="true"
         android:id="@+id/error_overlay">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="48sp"
             android:textColor="#FF0000"
             android:id="@+id/tv_error_icon"
             android:text="[ ! ]"
             android:textStyle="bold" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="16sp"
             android:textColor="#FF0000"
             android:layout_marginTop="8dp"
             android:id="@+id/tv_error_code_digit"
             android:text="INTERNAL_ERROR: 0000"
             android:textStyle="bold" />

        <View
             android:layout_height="1dp"
             android:layout_width="120dp"
             android:background="#FF0000"
             android:layout_marginTop="16dp" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:fontFamily="monospace"
             android:textSize="12sp"
             android:textColor="#FFFFFF"
             android:layout_marginTop="20dp"
             android:id="@+id/tv_error_message"
             android:text="UNAUTHORIZED INTERVENTION DETECTED" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:fontFamily="monospace"
             android:textSize="13sp"
             android:textColor="#FF0000"
             android:layout_marginTop="12dp"
             android:id="@+id/tv_self_destruct_timer"
             android:text="SHIELD LOCKDOWN IN: 4.0s"
             android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
