<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     xmlns:tools="http://schemas.android.com/tools"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="#000000"
     android:fitsSystemWindows="true"
     tools:context=".MainActivity">

    <androidx.appcompat.widget.Toolbar
         android:layout_height="?attr/actionBarSize"
         android:layout_width="match_parent"
         android:background="#000000"
         android:elevation="4dp"
         app:layout_constraintTop_toTopOf="parent"
         app:title="@string/main_title"
         app:layout_constraintStart_toStartOf="parent"
         app:titleTextColor="#00FF41"
         app:layout_constraintEnd_toEndOf="parent"
         app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
         android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
         android:id="@+id/toolbar_secure" />

    <TextView
         android:layout_height="wrap_content"
         android:layout_width="wrap_content"
         android:layout_margin="16dp"
         app:layout_constraintStart_toStartOf="parent"
         android:fontFamily="monospace"
         android:textSize="12sp"
         android:textColor="#00FF41"
         app:layout_constraintTop_toBottomOf="@id/toolbar_secure"
         android:id="@+id/tv_security_status"
         android:text="@string/log_security_active"
         android:textStyle="bold" />

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="wrap_content"
         android:orientation="vertical"
         app:layout_constraintStart_toStartOf="parent"
         android:layout_marginTop="4dp"
         android:layout_marginStart="16dp"
         app:layout_constraintTop_toBottomOf="@id/tv_security_status"
         android:id="@+id/ll_header_info">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="10sp"
             android:textColor="#888888"
             android:id="@+id/tv_author"
             android:text="Developer: Nguyen Minh Toi" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="10sp"
             android:textColor="#00FFFF"
             android:id="@+id/tv_version"
             android:text="@string/version_label" />

    </LinearLayout>

    <View
         android:layout_height="1dp"
         android:layout_width="match_parent"
         android:background="#1A1A1A"
         android:layout_marginHorizontal="16dp"
         android:layout_marginTop="10dp"
         app:layout_constraintTop_toBottomOf="@id/ll_header_info"
         android:id="@+id/divider" />

    <ScrollView
         android:layout_height="0dp"
         android:layout_width="match_parent"
         android:scrollbars="none"
         android:layout_marginTop="8dp"
         app:layout_constraintBottom_toBottomOf="parent"
         android:paddingHorizontal="16dp"
         app:layout_constraintTop_toBottomOf="@id/divider">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:orientation="vertical"
             android:paddingBottom="100dp">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:fontFamily="monospace"
                 android:textSize="13sp"
                 android:textColor="#FFFFFF"
                 android:lineSpacingExtra="4dp"
                 android:id="@+id/tv_device_info"
                 android:text="@string/log_scanning_integrity" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
         android:layout_height="match_parent"
         android:layout_width="match_parent"
         android:visibility="gone"
         android:background="#000000"
         android:gravity="center"
         android:clickable="true"
         android:elevation="50dp"
         android:padding="24dp"
         android:orientation="vertical"
         android:focusable="true"
         android:id="@+id/error_overlay">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="60sp"
             android:textColor="#FF0000"
             android:id="@+id/tv_error_icon"
             android:text="[ ! ]"
             android:textStyle="bold" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:fontFamily="monospace"
             android:textSize="18sp"
             android:textColor="#FF0000"
             android:layout_marginTop="10dp"
             android:id="@+id/tv_error_code_digit"
             android:text="INTERNAL_ERROR: 0000"
             android:textStyle="bold" />

        <View
             android:layout_height="1dp"
             android:layout_width="150dp"
             android:background="#FF0000"
             android:layout_marginTop="20dp" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:fontFamily="monospace"
             android:textSize="13sp"
             android:textColor="#FFFFFF"
             android:layout_marginTop="25dp"
             android:id="@+id/tv_error_message"
             android:text="@string/log_root_detected" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:fontFamily="monospace"
             android:textSize="14sp"
             android:textColor="#FF0000"
             android:layout_marginTop="15dp"
             android:id="@+id/tv_self_destruct_timer"
             android:text="SHIELD LOCKDOWN IN: 4.0s"
             android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>